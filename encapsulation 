#include <iostream>
#include <string>

using namespace std;

// Abstract Base Class
class Vehicle {
protected:
    string brand;
    int speed;

public:
    Vehicle(string b) : brand(b), speed(0) {}

    // Pure Virtual Function (Abstraction)
    // This forces every child class to create its own 'accelerate' logic.
    virtual void accelerate() = 0; 

    void stop() {
        speed = 0;
        cout << brand << " has stopped." << endl;
    }
};

// Derived Class 1
class SportsCar : public Vehicle {
public:
    SportsCar(string b) : Vehicle(b) {}

    // Polymorphism: Specific implementation for a SportsCar
    void accelerate() override {
        speed += 50;
        cout << brand << " roars! Speed is now " << speed << " km/h." << endl;
    }
};

// Derived Class 2
class Truck : public Vehicle {
public:
    Truck(string b) : Vehicle(b) {}

    // Polymorphism: Specific implementation for a Truck
    void accelerate() override {
        speed += 10;
        cout << brand << " hauls slowly. Speed is now " << speed << " km/h." << endl;
    }
};

int main() {
    // We can use a pointer of the Base type to point to different Child objects
    Vehicle* myGarage[2];

    myGarage[0] = new SportsCar("Ferrari");
    myGarage[1] = new Truck("Volvo");

    for(int i = 0; i < 2; i++) {
        myGarage[i]->accelerate(); // Calls the correct version automatically
    }

    // Cleanup
    delete myGarage[0];
    delete myGarage[1];

    return 0;
}
